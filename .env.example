# Runtime
REDIS_URL=redis://127.0.0.1:6379/0
RUNTIME_DATA_DIR=./data/runtime
SQLITE_PATH=./data/runtime/koresim.sqlite3
PARQUET_PATH=./data/nemotron_korea_personas.parquet
PERSONAS_DATA_DIR=./data/personas
DEFAULT_COUNTRY_ID=kr
# Throughput. OpenAI multi-worker: CONCURRENCY is per-run fanout; LLM_MAX_RPM
# is the GLOBAL fleet budget when LLM_RPM_LIMITER=redis (required for WORKER_COUNT>1).
# Re-run scripts/probe_llm_rate_limits.py after changing provider or tier.
CONCURRENCY=48
LLM_MAX_RPM=2000
LLM_RPM_LIMITER=auto
LLM_RPM_REDIS_KEY=koresim:llm:rpm
WORKER_COUNT=10
# empty = auto: true when WORKER_COUNT<=1, false when multi-worker
INTERRUPT_ACTIVE_RUNS_ON_STARTUP=
# Event booth mode (150 visitors): sample caps + queue admission
KORESIM_EVENT_MODE=false
# 0 = unlimited free runs for authenticated accounts
KORESIM_FREE_RUN_LIMIT=0
EVENT_DEFAULT_SAMPLE_SIZE=100
EVENT_MAX_SAMPLE_SIZE=300
EVENT_MAX_QUEUED_RUNS=40
MAX_SAMPLE_SIZE=2000
LLM_MAX_CONNECTIONS=256
LLM_SDK_MAX_RETRIES=0
LLM_TIMEOUT_SECONDS=60
LLM_RETRY_ATTEMPTS=4
LLM_RETRY_BACKOFF_SECONDS=2
LLM_RETRY_MAX_BACKOFF_SECONDS=30

# Target provider: upstage | openai | mono | gemini | litellm | fake
# "openai" and "mono" both use the OpenAI-compatible Chat Completions path.
LLM_BACKEND=upstage
STARTUP_ITEM_VALIDATION_PROTOCOL_VERSION=v1

# --- Upstage Solar (rollback / current production until OpenAI cutover) ---
# Single Upstage API key (backward-compatible fallback)
UPSTAGE_API_KEY=
# Per-key variables for round-robin throughput. When UPSTAGE_API_KEY_1 (and
# optionally UPSTAGE_API_KEY_2) are set, the system uses them instead of the
# single UPSTAGE_API_KEY. Each key gets its own httpx connection pool, raising
# the aggregate rate ceiling (~400-500 RPM × N keys).
UPSTAGE_API_KEY_1=
UPSTAGE_API_KEY_2=
UPSTAGE_BASE_URL=https://api.upstage.ai/v1
UPSTAGE_MODEL=solar-pro2

# --- OpenAI / ChatGPT API (single key; cost-optimized task routing) ---
# Preferred: set LLM_BACKEND=openai (or mono). Put the one API key here.
# File path loaded by the app: <project-root>/.env (never commit real values)
MONO_BASE_URL=https://api.openai.com/v1
MONO_API_KEY=
# Friendly aliases accepted when MONO_* is empty:
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-5.4-nano
MONO_MODEL=gpt-5.4-nano

# Task-tiered models (override per backend)
# Solar (when LLM_BACKEND=upstage):
MODEL_PERSONA_DEFAULT=solar-pro2
MODEL_PERSONA_STRONG=solar-pro2
MODEL_ANALYSIS_DEFAULT=solar-pro2
MODEL_REPORT_DEFAULT=solar-pro2
MODEL_REPAIR_DEFAULT=solar-pro2
# OpenAI cost-optimized matrix (when LLM_BACKEND=openai|mono):
# MODEL_PERSONA_DEFAULT=gpt-5.4-nano
# MODEL_PERSONA_STRONG=gpt-5.4-mini
# MODEL_ANALYSIS_DEFAULT=gpt-5.6-luna
# MODEL_REPORT_DEFAULT=gpt-5.6-luna
# MODEL_REPAIR_DEFAULT=gpt-5.4-nano
# LLM_MAX_RPM=450
# Optional reasoning params for analysis/report/qa only (not persona fanout)
# e.g. {"reasoning_effort":"low"}
MODEL_AGENT_EXTRA_BODY_JSON=

# Persona pools (B-3): dgist becomes available once the parquet exists
DGIST_PARQUET_PATH=./data/dgist_personas.parquet

# Token cost model (public prices, no secrets)
MODEL_PRICE_TABLE_PATH=./config/model_prices.json

# Temporary validated rollback provider; leave unused in Solar mode
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-3-flash-preview

# Optional LiteLLM control plane
LLM_GATEWAY_BASE_URL=http://127.0.0.1:4000/v1
LLM_GATEWAY_API_KEY=

# Result workflow and interactive safeguards
ENABLE_LANGGRAPH=true
ENABLE_LLM_AGENTS=true
INTERACTIVE_LLM_ACTIONS_PER_HOUR=20
INTERACTIVE_FOLLOWUP_MAX_SAMPLE_SIZE=12

# Metadata-only observability
OBSERVABILITY_PROVIDER=langfuse
LLM_TRACE_MODE=metadata_only
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# App auth (placeholders only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KORESIM_SESSION_SECRET=
KORESIM_AUTH_REDIRECT_URI=https://example.com/api/auth/google/callback

# Serper.dev Web Search API (Google Search)
# Key auto-activates autofill market grounding (C-4); WEB_SEARCH_ENABLED
# accepts auto/true/false.
SERPER_API_KEY=
WEB_SEARCH_ENABLED=auto

# Remote MCP session-only interim boundary; general remote hosts require future OAuth
KORESIM_MCP_ALLOWED_ORIGINS=https://arabesque.cc
