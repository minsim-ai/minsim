#!/usr/bin/env bash
# Blocks commits that reintroduce public-repo sensitive paths or local path leaks.
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "${ROOT}" ]]; then
  exit 0
fi
cd "${ROOT}"
if [[ -f scripts/check_public_tree_hygiene.py ]]; then
  if command -v uv >/dev/null 2>&1; then
    uv run python scripts/check_public_tree_hygiene.py
  else
    python3 scripts/check_public_tree_hygiene.py
  fi
fi
